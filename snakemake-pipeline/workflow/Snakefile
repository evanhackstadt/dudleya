# ---- Rule 15: ngsDist ----
rule ngsdist:
    input:
        beagle = os.path.join(DATA_DIR, "angsd_runs/<name>/population.beagle.gz"),
        info = "results/<name>/info/population.info"
    output:
        dist = "results/<name>/ngsdist/population.dist",
        n_sites = "results/<name>/ngsdist/n_sites.txt"
    params:
        name = config["output_name"],
        n_ind = N_SAMPLES
    threads: 32
    resources:
        slurm_partition = "mem",
        runtime = 1440,      # 24 hours
        mem_mb = lambda wc, input, attempt: attempt * max(20 * input.size_mb, 32000),    # 32GB or scale by input size
        cpus_per_task = lambda wildcards, threads: threads
    shell:
        """
        N_SITES=$(zcat {input.beagle} | tail -n +2 | wc -l)

        echo $N_SITES > {output.n_sites}

        ngsDist \
            --geno {input.beagle} \
            --probs \
            --n_ind {params.n_ind} \
            --n_sites $N_SITES \
            --labels {input.info} \
            --pairwise_del \
            --avg_nuc_dist \
            --evol_model 0 \
            --out {output.dist} \
            --n_threads {threads} \
            --verbose 2
        """

# ---- Rule 16: Analyze Distance Matrix ----
# Reports:
#   - Mean between-species pairwise distances with SE
#   - Permutation tests for between-species distance comparisons
#     (accounts for non-independence in pairwise distance matrices)
#   - Focal analysis of putative hybrid CY_HUN_LP_267_Du-686:
#     mean distances to each species + permutation-based affinity tests
rule analyze_ngsdist:
    input:
        dist = "results/<name>/ngsdist/population.dist",
        info = "results/<name>/info/population.info"
    output:
        report = "results/<name>/ngsdist/distance_analysis.txt"
    conda:
        "/WAVE/projects/whittalllab/conda_envs/visualization"
    script:
        "scripts/ngsdist_analyze.py"


# ---- Rule 17: Aggregate QC Report ----
rule aggregate_qc:
    input:
        fastp_jsons = expand(os.path.join(DATA_DIR, "qc_reports_reads", "{sample}_fastp_report.json"), sample=SAMPLES),
        flagstats   = expand(os.path.join(DATA_DIR, "qc_reports_reads", "{sample}_flagstat.txt"), sample=SAMPLES),
        depthSample = os.path.join(DATA_DIR, "angsd_runs/<name>/population.depthSample")
    output:
        csv  = "results/<name>/qc/aggregate_qc.csv",
        plot = "results/<name>/qc/aggregate_qc.png"
    conda:
        "/WAVE/projects/whittalllab/conda_envs/visualization"
    script:
        "scripts/aggregate_qc.py"